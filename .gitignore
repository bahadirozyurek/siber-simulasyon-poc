cat << 'EOF' > .gitignore
## --- .NET GitIgnore ---
[Dd]ebug/
[Rr]elease/
x64/
x86/
bincrafter/
obj/
bin/
Properties/launchSettings.json
.vs/
.vscode/
.cursor
## --- Node/Frontend GitIgnore ---
node_modules/
/frontend/dist
/frontend/build
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache
.oxlintcache

## --- OS GitIgnore ---
.DS_Store
Thumbs.db
EOF